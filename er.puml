@startuml
skinparam classAttributeIconSize 0
hide circle

' Class Base de Autenticação - Comum a TODOS do sistema
abstract class Usuario {
  Id_Usuario : int
  nome : string
  login : string
  senha : string
  tipo_usuario : TipoUsuario
}

' Classe Intermediária apenas para quem precisa de cadastro completo
abstract class PerfilCompleto {
  cpf : string
  rg : string
  email : string
  telefone : string
  cep : string
  logradouro : string
  numero : int
  complemento : string
  bairro : string
  cidade : string
  uf : string
}

class Administrador {
  ' Herda apenas ID, Nome, Login, Senha e TipoUsuario
}

class Secretária {
  ' Herda tudo de Usuario + PerfilCompleto
}

class Responsável {
  ' Herda tudo de Usuario + PerfilCompleto
}

class Aluno {
  Nivel_escolar : String
  Instituicao_de_ensino : string
}

class Professor {
  formacao : string
  curriculo : string
}

class "Registro de Aula" as RegistroDeAula {
  Id_Aula : int
  data : date
  hora_Inicio : time
  hora_Termino : time
  duracao : int
  conteudo : String
  licao_de_casa : String
  desemp_Individual : String
}

class "Agenda Disponibilidade" as AgendaDisponibilidade {
  id_disp : int
  data : date
  horarios : List<time>
}

class Despesa {
  Id_despesa : int
  titulo : string
  valor : float
  categoria : string
  status : string
  descricao : string
  arquivo : string
}

class "Agendamento de Aula" as AgendamentoDeAula {
  Id_Agendamento : int
  data : date
  horario : time
  cancelada : bool
}

class Pagamento {
  Id_pagamento : int
  nome_Pagador : String
  valor : float
  categoria : String
  data_Pagamento : date
  status : bool
}

class "Planos de aulas" as PlanosDeAulas {
  id_plano : int
  nome : string
  status : bool
  descricao : String
  valor_mensal : float
  num_aulas : int
  recursos : List<String>
  icone : String
}

class Cartao {
  nome_Cartao : String
  numero_Cartao : int
  validade : date
  codigo_cvv : int
  parcelas : int
}

class Pix {
  chave_Pix : String
  qrcode : String
  copia_e_Cola : String
}

class Boleto {
  cod_de_Barras : String
  data_Vencimento : date
}

class Questionario {
  id_questionario : int
  titulo : string
  nivel_dificuldade : int
  embaralhar_perguntas : bool
  embaralhar_alternativas : bool
}

class Questao {
  id_questao : int
  enunciado : string
}

class Alternativa {
  id_alternativa : int
  descricao : string
  eh_correta : bool
}

class Disciplinas {
  Id_Disciplina : int
  Categoria : String
  Descricao : String
}

' === Hierarquia de Herança Corrigida ===
Usuario <|-- Administrador
Usuario <|-- PerfilCompleto

PerfilCompleto <|-- Secretária
PerfilCompleto <|-- Responsável
PerfilCompleto <|-- Aluno
PerfilCompleto <|-- Professor

Pagamento <|-- Cartao
Pagamento <|-- Pix
Pagamento <|-- Boleto

' === Relacionamentos e Multiplicidades ===
Responsável "1" -- "1..*" Aluno : gerencia
Secretária "1" -- "0..*" Despesa : registra

Aluno "1" -- "0..*" Pagamento : realiza
Aluno "*" -- "0..1" PlanosDeAulas : assina
Aluno "1..*" -- "*" AgendamentoDeAula : participa
Aluno "1" -- "*" Questionario : responde

Professor "1" -- "*" RegistroDeAula : preenche
Professor "1" *-- "1" AgendaDisponibilidade : possui
Professor "1" --> "*" Questionario : elabora
Professor "*" -- "*" Disciplinas : leciona

AgendamentoDeAula "*" --> "1" Professor : alocado para
Pagamento "*" -- "0..1" PlanosDeAulas : referente a

Questionario "1" *-- "1..*" Questao : contem
Questao "1" *-- "1..*" Alternativa : possui
Questionario "*" --> "0..1" Disciplinas : pertence a

@enduml